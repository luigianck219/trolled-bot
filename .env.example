# ========================
#   TROLLED BOT — .env
# ========================

# Token del tuo bot Discord (obbligatorio)
# Trovalo su https://discord.com/developers/applications
DISCORD_TOKEN=il_tuo_token_qui

# Nome del ruolo Staff nel server (default: Staff)
STAFF_ROLE_NAME=Staff

# ID del canale dove vengono pubblicati i post con le clip
# Lascia vuoto per usare il canale dove viene eseguito il comando
POST_CHANNEL_ID=

# Percorso database SQLite (non cambiare su Railway, viene gestito automaticamente)
# DB_PATH=./data/trolled.db
